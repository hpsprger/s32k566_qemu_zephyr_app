diff --git a/hw/arm/s32k5xx.c b/hw/arm/s32k5xx.c
new file mode 100644
index 0000000..164ceb8
--- /dev/null
+++ b/hw/arm/s32k5xx.c
@@ -0,0 +1,58 @@
+/*
+ * S32K566 Evaluation Board Machine
+ *
+ * NXP S32K566 (Cortex-M7) evaluation board emulation.
+ * Runs Zephyr RTOS applications.
+ *
+ * Copyright (c) 2025 OpenClaw
+ *
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "qemu/osdep.h"
+#include "qapi/error.h"
+#include "hw/core/boards.h"
+#include "hw/core/qdev-properties.h"
+#include "hw/core/qdev-clock.h"
+#include "qemu/error-report.h"
+#include "hw/arm/s32k5xx_soc.h"
+#include "hw/arm/boot.h"
+#include "hw/arm/machines-qom.h"
+
+/* Main SYSCLK frequency in Hz (200 MHz for S32K566) */
+#define SYSCLK_FRQ 200000000ULL
+
+static void s32k566_evb_init(MachineState *machine)
+{
+    DeviceState *dev;
+    Clock *sysclk;
+
+    /* This clock doesn't need migration because it is fixed-frequency */
+    sysclk = clock_new(OBJECT(machine), "SYSCLK");
+    clock_set_hz(sysclk, SYSCLK_FRQ);
+
+    dev = qdev_new(TYPE_S32K5XX_SOC);
+    object_property_add_child(OBJECT(machine), "soc", OBJECT(dev));
+    sysbus_realize_and_unref(SYS_BUS_DEVICE(dev), &error_fatal);
+
+    /* Load the ELF/raw binary kernel */
+    armv7m_load_kernel(S32K5XX_SOC(dev)->armv7m.cpu,
+                       machine->kernel_filename,
+                       S32K_FLASH_ADDR, S32K_FLASH_SIZE);
+}
+
+static void s32k566_evb_machine_init(MachineClass *mc)
+{
+    static const char * const valid_cpu_types[] = {
+        ARM_CPU_TYPE_NAME("cortex-m7"),
+        NULL
+    };
+
+    mc->desc = "NXP S32K566 Evaluation Board (Cortex-M7)";
+    mc->init = s32k566_evb_init;
+    mc->valid_cpu_types = valid_cpu_types;
+    mc->ignore_memory_transaction_failures = true;
+    mc->default_cpu_type = ARM_CPU_TYPE_NAME("cortex-m7");
+}
+
+DEFINE_MACHINE_ARM("s32k566-evb", s32k566_evb_machine_init)
diff --git a/hw/arm/s32k5xx_soc.c b/hw/arm/s32k5xx_soc.c
new file mode 100644
index 0000000..523797b
--- /dev/null
+++ b/hw/arm/s32k5xx_soc.c
@@ -0,0 +1,232 @@
+/*
+ * NXP S32K5XX SoC
+ *
+ * Minimal S32K5xx SoC for Zephyr RTOS on QEMU.
+ * Memory map from S32K566 Zephyr DTS.
+ *
+ * Copyright (c) 2025 OpenClaw
+ *
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "qemu/osdep.h"
+#include "qapi/error.h"
+#include "system/address-spaces.h"
+#include "system/system.h"
+#include "hw/arm/s32k5xx_soc.h"
+#include "hw/core/qdev-clock.h"
+#include "hw/misc/unimp.h"
+
+/* Peripheral base addresses */
+#define S32K_LPUART0_ADDR   0x400e0000
+#define S32K_STM0_ADDR      0x405a4000
+#define S32K_PIT0_ADDR      0x405a0000
+#define S32K_SWT0_ADDR      0x40b18000
+#define S32K_CLOCK_ADDR     0x42110000
+#define S32K_SIUL2_ADDR     0x40014000
+#define S32K_MC_ME_ADDR     0x40498000
+#define S32K_CPE_MC_ME_ADDR 0x41050000
+#define S32K_LPE_MC_ME_ADDR 0x4206c000
+#define S32K_LPUART0_IRQ    155
+
+#define S32K_CPUCLK_FRQ     200000000ULL
+
+#define S32K_MC_ME_SIZE     0x4000
+#define MC_ME_PRTN_STRIDE   0x200
+#define MC_ME_PRTN_PUPD     0x104
+#define MC_ME_PRTN_STAT     0x110
+#define MC_ME_PRTN_CLKEN    0x130
+#define MC_ME_PUPD_PCUD     0x1
+
+/*
+ * Zephyr's S32K566 image reserves the first 0x100 bytes of MRAM for the
+ * boot header and places the Cortex-M vector table at 0x08000400.  The
+ * ARMv7M reset logic reads SP/PC from VTOR, so leaving VTOR at zero makes it
+ * fetch zero-filled boot-header padding and immediately lock up at PC=0.
+ */
+#define S32K_INIT_VTOR      0x08000400
+
+static bool s32k_mc_me_is_prtn_offset(hwaddr off, hwaddr base, hwaddr len)
+{
+    if (off < base) {
+        return false;
+    }
+
+    return ((off - base) % MC_ME_PRTN_STRIDE) < len;
+}
+
+static bool s32k_mc_me_is_pupd(hwaddr off)
+{
+    return off >= MC_ME_PRTN_PUPD &&
+           ((off - MC_ME_PRTN_PUPD) % MC_ME_PRTN_STRIDE) == 0;
+}
+
+static hwaddr s32k_mc_me_to_clken_offset(hwaddr stat_off)
+{
+    return stat_off + (MC_ME_PRTN_CLKEN - MC_ME_PRTN_STAT);
+}
+
+static hwaddr s32k_mc_me_to_stat_offset(hwaddr clken_off)
+{
+    return clken_off - (MC_ME_PRTN_CLKEN - MC_ME_PRTN_STAT);
+}
+
+static uint64_t s32k_mc_me_read(void *opaque, hwaddr addr, unsigned size)
+{
+    S32K5XXState *s = S32K5XX_SOC(opaque);
+    hwaddr off = addr & ~3;
+    uint32_t value;
+
+    if (off >= S32K_MC_ME_SIZE) {
+        return 0;
+    }
+
+    if (s32k_mc_me_is_prtn_offset(off, MC_ME_PRTN_STAT, 0x20)) {
+        value = s->mc_me_regs[s32k_mc_me_to_clken_offset(off) / 4];
+    } else {
+        value = s->mc_me_regs[off / 4];
+    }
+
+    if (s32k_mc_me_is_pupd(off)) {
+        value &= ~MC_ME_PUPD_PCUD;
+    }
+
+    return value;
+}
+
+static void s32k_mc_me_write(void *opaque, hwaddr addr, uint64_t val64,
+                             unsigned size)
+{
+    S32K5XXState *s = S32K5XX_SOC(opaque);
+    hwaddr off = addr & ~3;
+    uint32_t value = val64;
+
+    if (off >= S32K_MC_ME_SIZE) {
+        return;
+    }
+
+    if (s32k_mc_me_is_pupd(off)) {
+        value &= ~MC_ME_PUPD_PCUD;
+    }
+
+    s->mc_me_regs[off / 4] = value;
+
+    if (s32k_mc_me_is_prtn_offset(off, MC_ME_PRTN_CLKEN, 0x20)) {
+        s->mc_me_regs[s32k_mc_me_to_stat_offset(off) / 4] = value;
+    }
+}
+
+static const MemoryRegionOps s32k_mc_me_ops = {
+    .read = s32k_mc_me_read,
+    .write = s32k_mc_me_write,
+    .endianness = DEVICE_NATIVE_ENDIAN,
+    .valid.min_access_size = 1,
+    .valid.max_access_size = 4,
+};
+
+static void s32k5xx_soc_initfn(Object *obj)
+{
+    S32K5XXState *s = S32K5XX_SOC(obj);
+    object_initialize_child(obj, "armv7m", &s->armv7m, TYPE_ARMV7M);
+    object_initialize_child(obj, "lpuart0", &s->lpuart[0], TYPE_NXP_LPUART);
+}
+
+static void s32k5xx_soc_realize(DeviceState *dev_soc, Error **errp)
+{
+    S32K5XXState *s = S32K5XX_SOC(dev_soc);
+    DeviceState *armv7m, *dev;
+    SysBusDevice *busdev;
+    Error *err = NULL;
+    MemoryRegion *sysmem = get_system_memory();
+
+    /* Create SRAM */
+    memory_region_init_ram(&s->sram0, NULL, "s32k.sram0", 512 * 1024, &err);
+    if (err) { error_propagate(errp, err); return; }
+    memory_region_add_subregion(sysmem, 0x21000000, &s->sram0);
+
+    memory_region_init_ram(&s->sram1, NULL, "s32k.sram1", 512 * 1024, &err);
+    if (err) { error_propagate(errp, err); return; }
+    memory_region_add_subregion(sysmem, 0x21080000, &s->sram1);
+
+    memory_region_init_ram(&s->sram2, NULL, "s32k.sram2", 512 * 1024, &err);
+    if (err) { error_propagate(errp, err); return; }
+    memory_region_add_subregion(sysmem, 0x21100000, &s->sram2);
+
+    /* Create Flash */
+    memory_region_init_rom(&s->flash, OBJECT(dev_soc), "s32k.flash",
+                           32 * 1024 * 1024, &err);
+    if (err) { error_propagate(errp, err); return; }
+    memory_region_add_subregion(sysmem, 0x08000000, &s->flash);
+
+    /* Alias first 256 bytes of flash to 0x0 for Cortex-M vector table */
+    memory_region_init_alias(&s->flash_alias, OBJECT(dev_soc), "s32k.flash_alias",
+                            &s->flash, 0, 0x400);
+    memory_region_add_subregion(sysmem, 0x00000000, &s->flash_alias);
+
+    /* ARMv7M (Cortex-M7) */
+    armv7m = DEVICE(&s->armv7m);
+    qdev_prop_set_uint32(armv7m, "num-irq", 240);
+    qdev_prop_set_uint8(armv7m, "num-prio-bits", 4);
+    qdev_prop_set_uint32(armv7m, "init-svtor", S32K_INIT_VTOR);
+    qdev_prop_set_uint32(armv7m, "init-nsvtor", S32K_INIT_VTOR);
+    qdev_prop_set_string(armv7m, "cpu-type", ARM_CPU_TYPE_NAME("cortex-m7"));
+    if (!s->sysclk) {
+        s->sysclk = clock_new(OBJECT(dev_soc), "SYSCLK");
+        clock_set_hz(s->sysclk, S32K_CPUCLK_FRQ);
+    }
+    qdev_connect_clock_in(armv7m, "cpuclk", s->sysclk);
+    object_property_set_link(OBJECT(&s->armv7m), "memory",
+                             OBJECT(sysmem), &error_abort);
+    if (!sysbus_realize(SYS_BUS_DEVICE(&s->armv7m), errp)) {
+        return;
+    }
+
+    /* Unimplemented peripherals */
+    create_unimplemented_device("s32k.stm0",  S32K_STM0_ADDR,  0x4000);
+    create_unimplemented_device("s32k.pit0",  S32K_PIT0_ADDR,  0x4000);
+    create_unimplemented_device("s32k.swt0",  S32K_SWT0_ADDR,  0x4000);
+    create_unimplemented_device("s32k.clock", S32K_CLOCK_ADDR, 0x4000);
+    create_unimplemented_device("s32k.siul2", S32K_SIUL2_ADDR, 0x10000);
+
+    /* MC_ME: minimal mode entry model; enough for Zephyr startup clock gates. */
+    memory_region_init_io(&s->mc_me, OBJECT(dev_soc), &s32k_mc_me_ops, s,
+                          "s32k.mc_me", S32K_MC_ME_SIZE);
+    memory_region_add_subregion(sysmem, S32K_MC_ME_ADDR, &s->mc_me);
+    memory_region_init_io(&s->cpe_mc_me, OBJECT(dev_soc), &s32k_mc_me_ops, s,
+                          "s32k.cpe_mc_me", S32K_MC_ME_SIZE);
+    memory_region_add_subregion(sysmem, S32K_CPE_MC_ME_ADDR, &s->cpe_mc_me);
+    memory_region_init_io(&s->lpe_mc_me, OBJECT(dev_soc), &s32k_mc_me_ops, s,
+                          "s32k.lpe_mc_me", S32K_MC_ME_SIZE);
+    memory_region_add_subregion(sysmem, S32K_LPE_MC_ME_ADDR, &s->lpe_mc_me);
+
+    /* LPUART0 - console */
+    dev = DEVICE(&s->lpuart[0]);
+    qdev_prop_set_chr(dev, "chardev", serial_hd(0));
+    if (!sysbus_realize(SYS_BUS_DEVICE(dev), &err)) {
+        error_propagate(errp, err);
+        return;
+    }
+    busdev = SYS_BUS_DEVICE(dev);
+    sysbus_mmio_map(busdev, 0, S32K_LPUART0_ADDR);
+    sysbus_connect_irq(busdev, 0, qdev_get_gpio_in(armv7m, S32K_LPUART0_IRQ));
+}
+
+static void s32k5xx_soc_class_init(ObjectClass *klass, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+    dc->realize = s32k5xx_soc_realize;
+}
+
+static const TypeInfo s32k5xx_soc_info = {
+    .name          = TYPE_S32K5XX_SOC,
+    .parent        = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(S32K5XXState),
+    .instance_init = s32k5xx_soc_initfn,
+    .class_init    = s32k5xx_soc_class_init,
+};
+
+static void s32k5xx_soc_register_types(void)
+{
+    type_register_static(&s32k5xx_soc_info);
+}
+type_init(s32k5xx_soc_register_types)
