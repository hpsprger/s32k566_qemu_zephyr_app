diff --git a/hw/char/nxp_lpuart.c b/hw/char/nxp_lpuart.c
new file mode 100644
index 0000000..6a54096
--- /dev/null
+++ b/hw/char/nxp_lpuart.c
@@ -0,0 +1,134 @@
+/*
+ * NXP LPUART (Low Power UART) emulation
+ *
+ * Minimal implementation for S32K5xx series.
+ * Supports basic TX operation for console output.
+ *
+ * Copyright (c) 2025 OpenClaw
+ *
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "qemu/osdep.h"
+#include "hw/char/nxp_lpuart.h"
+#include "hw/core/irq.h"
+#include "hw/core/qdev-properties.h"
+#include "hw/core/qdev-properties-system.h"
+#include "qemu/log.h"
+#include "qemu/module.h"
+#include "system/system.h"
+
+static uint64_t nxp_lpuart_read(void *opaque, hwaddr addr, unsigned size)
+{
+    NXPLpuartState *s = NXP_LPUART(opaque);
+
+    switch (addr) {
+    case LPUART_VERID:  return s->verid;
+    case LPUART_PARAM:  return s->param;
+    case LPUART_GLOBAL: return s->global;
+    case LPUART_PINCFG: return s->pincfg;
+    case LPUART_BAUD:   return s->baud;
+    case LPUART_STAT:   return s->stat;
+    case LPUART_CTRL:   return s->ctrl;
+    case LPUART_DATA:   return 0;
+    case LPUART_MATCH:  return s->match;
+    case LPUART_MODIR:  return s->modir;
+    case LPUART_FIFO:   return s->fifo;
+    case LPUART_WATER:  return s->water;
+    default:
+        qemu_log_mask(LOG_GUEST_ERROR, "%s: Bad offset 0x%" HWADDR_PRIx "\n",
+                      __func__, addr);
+        return 0;
+    }
+}
+
+static void nxp_lpuart_write(void *opaque, hwaddr addr, uint64_t val64,
+                             unsigned size)
+{
+    NXPLpuartState *s = NXP_LPUART(opaque);
+    uint32_t value = val64;
+
+    switch (addr) {
+    case LPUART_VERID:  s->verid = value; break;
+    case LPUART_GLOBAL: s->global = value; break;
+    case LPUART_PINCFG: s->pincfg = value; break;
+    case LPUART_BAUD:   s->baud = value; break;
+    case LPUART_STAT:
+        s->stat &= ~value;
+        s->stat |= LPUART_STAT_TDRE | LPUART_STAT_TC;
+        break;
+    case LPUART_CTRL:
+        s->ctrl = value;
+        break;
+    case LPUART_DATA:
+        if (s->chr.chr) {
+            uint8_t c = value & 0xFF;
+            qemu_chr_fe_write(&s->chr, &c, 1);
+        }
+        s->stat |= LPUART_STAT_TDRE | LPUART_STAT_TC;
+        break;
+    case LPUART_MATCH: s->match = value; break;
+    case LPUART_MODIR: s->modir = value; break;
+    case LPUART_FIFO:  s->fifo = value; break;
+    case LPUART_WATER: s->water = value; break;
+    default:
+        qemu_log_mask(LOG_GUEST_ERROR, "%s: Bad offset 0x%" HWADDR_PRIx "\n",
+                      __func__, addr);
+    }
+}
+
+static const MemoryRegionOps nxp_lpuart_ops = {
+    .read = nxp_lpuart_read,
+    .write = nxp_lpuart_write,
+    .endianness = DEVICE_NATIVE_ENDIAN,
+    .valid.min_access_size = 1,
+    .valid.max_access_size = 4,
+};
+
+static void nxp_lpuart_realize(DeviceState *dev, Error **errp)
+{
+    NXPLpuartState *s = NXP_LPUART(dev);
+    s->verid = 0x04040005;
+    s->param = 0x00000303;
+    s->global = 0x00000000;
+    s->pincfg = 0x00000000;
+    s->baud = 0x0F000000;
+    s->stat = LPUART_STAT_TDRE | LPUART_STAT_TC;
+    s->ctrl = 0x00000000;
+    s->fifo = 0x00000000;
+    s->water = 0x00000000;
+}
+
+static void nxp_lpuart_init(Object *obj)
+{
+    NXPLpuartState *s = NXP_LPUART(obj);
+    sysbus_init_irq(SYS_BUS_DEVICE(obj), &s->irq);
+    memory_region_init_io(&s->mmio, obj, &nxp_lpuart_ops, s,
+                          TYPE_NXP_LPUART, NXP_LPUART_MMIO_SIZE);
+    sysbus_init_mmio(SYS_BUS_DEVICE(obj), &s->mmio);
+}
+
+static const Property nxp_lpuart_properties[] = {
+    DEFINE_PROP_CHR("chardev", NXPLpuartState, chr),
+};
+
+static void nxp_lpuart_class_init(ObjectClass *klass, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+    dc->realize = nxp_lpuart_realize;
+    device_class_set_props(dc, nxp_lpuart_properties);
+}
+
+static const TypeInfo nxp_lpuart_info = {
+    .name = TYPE_NXP_LPUART,
+    .parent = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(NXPLpuartState),
+    .instance_init = nxp_lpuart_init,
+    .class_init = nxp_lpuart_class_init,
+};
+
+static void nxp_lpuart_register_types(void)
+{
+    type_register_static(&nxp_lpuart_info);
+}
+type_init(nxp_lpuart_register_types)
diff --git a/include/hw/arm/s32k5xx_soc.h b/include/hw/arm/s32k5xx_soc.h
new file mode 100644
index 0000000..39808d3
--- /dev/null
+++ b/include/hw/arm/s32k5xx_soc.h
@@ -0,0 +1,50 @@
+/*
+ * NXP S32K5XX SoC
+ *
+ * Copyright (c) 2025 OpenClaw
+ *
+ * SPDX-License-Identifier: MIT
+ */
+
+#ifndef HW_ARM_S32K5XX_SOC_H
+#define HW_ARM_S32K5XX_SOC_H
+
+#include "hw/arm/armv7m.h"
+#include "hw/char/nxp_lpuart.h"
+#include "hw/core/clock.h"
+#include "qom/object.h"
+
+#define TYPE_S32K5XX_SOC "s32k5xx-soc"
+OBJECT_DECLARE_SIMPLE_TYPE(S32K5XXState, S32K5XX_SOC)
+
+#define S32K5XX_NUM_LPUARTS 1
+
